# ============================================================
# BaselineMLB — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (create in Stripe Dashboard → Products)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PREMIUM=price_...

# ── App ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Email Alerts (Resend) ────────────────────────────────────────────
RESEND_API_KEY=re_...
ALERT_FROM_EMAIL=alerts@baselinemlb.com

# ── Cron Security ────────────────────────────────────────────────────
# Random secret for authorizing Vercel cron calls to /api/alerts
CRON_SECRET=your-random-secret-here

# ── Optional: SendGrid fallback ──────────────────────────────────────
# SENDGRID_API_KEY=SG...
